# Copy to .env for local client scripts only. Never commit real values.

# AWS region where the signer Lambda is deployed
AWS_REGION=eu-west-1

# Deployed Lambda function name (from CDK output)
AWS_LAMBDA_FUNCTION_NAME=aws-kms-lambda-ethereum-eth-kms-clientFunction-XXXXXXXX

# Optional: BSC JSON-RPC endpoint for broadcasting signed txs (testnet recommended)
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# Network profile used by the Lambda (set at deploy time via CDK)
# ETH_NETWORK=bsc-testnet
# CHAIN_ID=97
